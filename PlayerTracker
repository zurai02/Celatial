function PlayerTracker:GetDistance(userId1, userId2)
    local pos1 = self:GetPosition(userId1)
    local pos2 = self:GetPosition(userId2)
    if pos1 and pos2 then
        return (pos1 - pos2).Magnitude
    end
    return nil
end

function PlayerTracker:GetAll()
    return self.Players
end

function PlayerTracker:GetAlive()
    local alive = {}
    for userId, data in pairs(self.Players) do
        if data.IsAlive then
            alive[userId] = data
        end
    end
    return alive
end

function PlayerTracker:GetClosest(userId)
    local myPos = self:GetPosition(userId)
    if not myPos then return nil end
    
    local closest = nil
    local closestDist = math.huge
    
    for uid, data in pairs(self.Players) do
        if uid ~= userId and data.IsAlive then
            local dist = (myPos - data.Position).Magnitude
            if dist < closestDist then
                closestDist = dist
                closest = data
            end
        end
    end
    
    return closest, closestDist
end

function PlayerTracker:Stop()
    for _, conn in ipairs(self.Connections) do
        conn:Disconnect()
    end
    self.Connections = {}
    self.Players = {}
end

return PlayerTracker
