local PlayerTracker = {}

PlayerTracker.Players = {}
PlayerTracker.UpdateInterval = 0.1
PlayerTracker.Connections = {}

function PlayerTracker:Start()
    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")
    
    local function trackPlayer(player)
        self.Players[player.UserId] = {
            Name = player.Name,
            DisplayName = player.DisplayName,
            UserId = player.UserId,
            Position = Vector3.new(0, 0, 0),
            LastPosition = Vector3.new(0, 0, 0),
            Velocity = Vector3.new(0, 0, 0),
            Health = 100,
            LastHealth = 100,
            MaxHealth = 100,
            Team = nil,
            IsAlive = true,
            HealthHistory = {},
            PositionHistory = {},
            LastSeen = tick(),
        }
        
        local function updateCharacter(character)
            if not character then return end
            
            local humanoid = character:WaitForChild("Humanoid", 5)
            local rootPart = character:WaitForChild("HumanoidRootPart", 5)
            
            if humanoid and rootPart then
                local data = self.Players[player.UserId]
                data.MaxHealth = humanoid.MaxHealth
                
                local conn = RunService.Heartbeat:Connect(function()
                    if not character.Parent then return end
                    if not rootPart.Parent then return end
                    
                    data.LastPosition = data.Position
                    data.Position = rootPart.Position
                    data.Velocity = rootPart.Velocity
                    data.LastHealth = data.Health
                    data.Health = humanoid.Health
                    data.IsAlive = humanoid.Health > 0
                    data.Team = player.Team and player.Team.Name or nil
                    data.LastSeen = tick()
                    
                    table.insert(data.HealthHistory, {
                        Time = tick(),
                        Health = data.Health,
                        Change = data.Health - data.LastHealth,
                    })
                    
                    if #data.HealthHistory > 50 then
                        table.remove(data.HealthHistory, 1)
                    end
                    
                    table.insert(data.PositionHistory, {
                        Time = tick(),
                        Position = data.Position,
                    })
                    
                    if #data.PositionHistory > 30 then
                        table.remove(data.PositionHistory, 1)
                    end
                end)
                
                table.insert(self.Connections, conn)
                
                humanoid.Died:Connect(function()
                    data.IsAlive = false
                    data.LastHealth = data.Health
                    data.Health = 0
                end)
            end
        end
        
        if player.Character then
            updateCharacter(player.Character)
        end
        
        player.CharacterAdded:Connect(updateCharacter)
        player.CharacterRemoving:Connect(function()
            if self.Players[player.UserId] then
                self.Players[player.UserId].IsAlive = false
            end
        end)
    end
    
    for _, player in ipairs(Players:GetPlayers()) do
        trackPlayer(player)
    end
    
    Players.PlayerAdded:Connect(trackPlayer)
    
    Players.PlayerRemoving:Connect(function(player)
        self.Players[player.UserId] = nil
    end)
end

function PlayerTracker:GetPosition(userId)
    local data = self.Players[userId]
    if data then
        return data.Position
    end
    return nil
end

